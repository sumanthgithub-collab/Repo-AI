# =============================================================
# RepoTalk — Environment Variables Template
# Copy this to .env and fill in your values.
# Never commit .env to git — only .env.example is tracked.
# =============================================================

# ----- Node.js Gateway -----
NODE_ENV=development
PORT=4000

# Clerk Auth (https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Supabase (https://supabase.com/dashboard)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Upstash Redis (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Internal service URL (FastAPI AI service)
AI_SERVICE_URL=http://localhost:8000

# ----- FastAPI AI Service -----

# LLM Provider: "groq" (default) or "ollama"
LLM_PROVIDER=groq

# Groq API (https://console.groq.com — free, no credit card)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local fallback — runs on your machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Qdrant Vector Database (https://cloud.qdrant.io — free tier)
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
# For local Docker Qdrant, use:
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Embedding model (runs locally — no API key needed)
EMBEDDING_MODEL=nomic-ai/nomic-embed-code-v1
EMBEDDING_DEVICE=cpu
# Set to "cuda" if you have a GPU

# Langfuse Observability (https://cloud.langfuse.com — free tier)
LANGFUSE_PUBLIC_KEY=pk-lf-your_langfuse_public_key
LANGFUSE_SECRET_KEY=sk-lf-your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
# For self-hosted: LANGFUSE_HOST=http://localhost:3001

# GitHub (for PR summarizer & webhook features)
GITHUB_TOKEN=ghp_your_github_pat_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ----- Frontend (Next.js) -----
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
