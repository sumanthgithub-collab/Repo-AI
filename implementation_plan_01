## 5. Database Schema (Prisma)

```prisma
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  repos     Repo[]
  sessions  Session[]
  createdAt DateTime @default(now())
}

model Repo {
  id            String   @id @default(cuid())
  githubUrl     String
  name          String
  languages     String[]  // ["python", "typescript"]
  framework     String?   // "nextjs", "fastapi", etc.
  conventions   String?   // auto-detected coding style
  status        String    @default("pending") // pending | ingesting | ready | error
  chunkCount    Int       @default(0)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  sessions      Session[]
  createdAt     DateTime @default(now())
}

model Session {
  id        String    @id @default(cuid())
  title     String?   // auto-named from first question
  repoId    String
  repo      Repo     @relation(fields: [repoId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  messages  Message[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id          String   @id @default(cuid())
  role        String   // "user" | "assistant"
  content     String
  citations   Json?    // [{file, line, snippet}]
  ragasScore  Json?    // {faithfulness, relevancy, precision}
  bookmarked  Boolean  @default(false)
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id])
  createdAt   DateTime @default(now())
}
```

